// prisma/schema.prisma
// Add these models to your existing schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  password          String
  profilePhoto      String?
  bio               String?
  dateOfBirth       DateTime?
  location          String?
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  groupMemberships   GroupMember[]
  ownedGroups        FamilyGroup[]    @relation("GroupAdmin")
  familyProfiles     FamilyProfile[]
  sentMessages       Message[]        @relation("MessageSender")
  conversationsAs1   Conversation[]   @relation("ConversationUser1")
  conversationsAs2   Conversation[]   @relation("ConversationUser2")
}

model FamilyGroup {
  id          String   @id @default(cuid())
  name        String
  coverPhoto  String?
  description String?
  inviteCode  String   @unique @default(cuid())
  adminId     String
  admin       User     @relation("GroupAdmin", fields: [adminId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        GroupMember[]
  familyProfiles FamilyProfile[]
  messages       Message[]       // group messages
}

model GroupMember {
  id       String      @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  group FamilyGroup @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model FamilyProfile {
  id      String @id @default(cuid())
  userId  String
  groupId String

  fatherName String?
  fatherId   String?
  motherName String?
  motherId   String?
  spouseName String?
  spouseId   String?

  childrenNames String[] @default([])
  childrenIds   String[] @default([])
  siblingNames  String[] @default([])
  siblingIds    String[] @default([])

  grandfatherPaternalName String?
  grandfatherPaternalId   String?
  grandmotherPaternalName String?
  grandmotherPaternalId   String?
  grandfatherMaternalName String?
  grandfatherMaternalId   String?
  grandmotherMaternalName String?
  grandmotherMaternalId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  group FamilyGroup @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

// ── Chat Models ──────────────────────────────────────────────────────────────

model Message {
  id        String      @id @default(cuid())
  content   String?     // text content (optional if image only)
  imageUrl  String?     // Cloudinary URL
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())

  senderId  String
  sender    User        @relation("MessageSender", fields: [senderId], references: [id])

  // Either groupId (group chat) or conversationId (DM) — one must be set
  groupId        String?
  group          FamilyGroup?  @relation(fields: [groupId], references: [id])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
}

enum MessageType {
  TEXT
  IMAGE
  TEXT_IMAGE
}

// DM conversation between exactly two users
model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user1Id   String
  user2Id   String
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id])

  messages  Message[]

  @@unique([user1Id, user2Id])
}
