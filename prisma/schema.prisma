
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  password          String
  profilePhoto      String?
  bio               String?
  dateOfBirth       DateTime?
  location          String?
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  groupMemberships GroupMember[]
  ownedGroups      FamilyGroup[]   @relation("GroupAdmin")
  familyProfiles   FamilyProfile[]
}

model FamilyGroup {
  id          String   @id @default(cuid())
  name        String
  coverPhoto  String?
  description String?
  inviteCode  String   @unique @default(cuid())
  adminId     String
  admin       User     @relation("GroupAdmin", fields: [adminId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        GroupMember[]
  familyProfiles FamilyProfile[]
}

model GroupMember {
  id       String      @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  group FamilyGroup @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

// One profile per user per group — describes their family relations
model FamilyProfile {
  id      String @id @default(cuid())
  userId  String
  groupId String

  // Father
  fatherName String?
  fatherId   String? // matched User.id in group (nullable)

  // Mother
  motherName String?
  motherId   String?

  // Spouse
  spouseName String?
  spouseId   String?

  // Children — stored as JSON arrays
  // e.g. ["Arjun", "Meera"]  and  ["clxxx1", null]
  childrenNames String[] @default([])
  childrenIds   String[] @default([]) // parallel array, "" = unmatched

  // Siblings
  siblingNames String[] @default([])
  siblingIds   String[] @default([])

  // Grandparents (paternal)
  grandfatherPaternalName String?
  grandfatherPaternalId   String?
  grandmotherPaternalName String?
  grandmotherPaternalId   String?

  // Grandparents (maternal)
  grandfatherMaternalName String?
  grandfatherMaternalId   String?
  grandmotherMaternalName String?
  grandmotherMaternalId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  group FamilyGroup @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}
